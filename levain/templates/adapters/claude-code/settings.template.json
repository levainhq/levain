{
  "permissions": {
    "allow": [
      "mcp__anneal_memory"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON}}\" \"${CLAUDE_PROJECT_DIR}/activation/hooks/session_start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON}}\" \"${CLAUDE_PROJECT_DIR}/activation/hooks/user_prompt_submit.py\""
          }
        ]
      }
    ]
  }
}
