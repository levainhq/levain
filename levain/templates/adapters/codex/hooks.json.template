{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON}}\" \"{{INSTALL_DIR}}/activation/hooks/session_start.py\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON}}\" \"{{INSTALL_DIR}}/activation/hooks/user_prompt_submit.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
